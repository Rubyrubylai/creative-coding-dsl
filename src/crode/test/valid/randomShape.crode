canvas "RandomShape" width 800 height 600 {
    let bubble = circle {
        radius random(20, 40) / 2
        color blue
    }

    let stars = star {
        size random(0, 30)
        color yellow
    }

    if random(0,1) lessThan 0.95 {
        draw stars at (random(0, 780), random(0, 200))
    } else {
        draw bubble at (random(0, 780), random(0, 200))
    }
}
