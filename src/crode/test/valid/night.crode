canvas "Night" width 800 height 600 background black {
    let snowflake = circle {
        radius rand(2, 6)
        color white
    }

    let stars = star {
        size rand(0, 30)
        color yellow
    }

    repeat 300 {
        if rand(0,1) lessThan 0.5 {
            draw snowflake at (rand(0,780), rand(0,580))
        } else {
            draw stars at (rand(0, 780), rand(0, 200)) rotate rand(0,90)
        }
    }
}
