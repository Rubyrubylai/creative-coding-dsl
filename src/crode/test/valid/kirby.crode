canvas "Kirby" width 800 height 600 {
  let body = circle {
    radius 135
    color pink
  }

  let foot = ellipse {
    width 105
    height 45
    color red
  }

  let hand = ellipse {
    width 75
    height 50
    color pink
  }

  let eye = ellipse {
    width 28
    height 70
    color black
  }

  let eye_shine = circle {
    radius 8
    color white
  }

  let cheek = ellipse {
    width 42
    height 22
    color red
  }

  let smile = arc {
    width 55
    height 35
    start 20
    stop 160
    color black
  }

  draw foot at (235, 355)
  draw foot at (365, 355)
  draw hand at (175, 255)
  draw hand at (425, 255)
  draw body at (300, 250)
  draw eye at (255, 220)
  draw eye at (345, 220)
  draw eye_shine at (260, 200)
  draw eye_shine at (350, 200)
  draw cheek at (225, 265)
  draw cheek at (375, 265)
  draw smile at (300, 270)
}
