canvas "Snow" width 800 height 600 {
    let snowflake = circle {
        radius random(2, 6)
        color black
    }

    let bubble = circle {
        radius random(20, 40) / 2
        color blue
    }

    let block = square {
        size random(20, 40)
        color red
    }

    let stars = star {
        size random(0, 30)
        color yellow
    }

    repeat 300 {
        if random(0,1) lessThan 0.95 {
            draw snowflake at (random(0,780), random(0,580))
        } else {
            draw stars at (random(0, 780), random(0, 200))
        }
    }

    for i in 0 to 8 step 0.5 {
        if i mod 1 equals 0.5 {
            draw bubble at (i * 100, 500)
        } else {
            draw block at (i * 100, 500)
        }
    }
}
