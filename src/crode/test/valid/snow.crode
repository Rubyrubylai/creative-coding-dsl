canvas "Snow" {
    let snowflake = circle {
        radius rand(0.02, 0.06)
        color black
    }

    let bubble = circle {
        radius 0.2
        color blue
    }

    repeat 300 {
        draw snowflake at (rand(0,7.8), rand(0,5.8))
    }

    for i in 0 to 8 step 0.6 {
        draw bubble at (i, 5)
        draw bubble at (i+0.1, 5.3)
    }
}